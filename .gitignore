# EduCore AI Platform — .gitignore

# ── Python ─────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/

# ── Virtual Environments ────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── Environment Files ───────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ── Testing ─────────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover

# ── Type Checking ────────────────────────────────────────────────────────────
.mypy_cache/
.dmypy.json

# ── Linting ─────────────────────────────────────────────────────────────────
.ruff_cache/

# ── IDE ──────────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~

# ── OS ───────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini

# ── Docker ───────────────────────────────────────────────────────────────────
*.log
logs/

# ── Alembic ──────────────────────────────────────────────────────────────────
# Keep versions tracked; exclude auto-generated output
alembic/versions/*.pyc

# ── Docs Build ───────────────────────────────────────────────────────────────
docs/_build/
site/
